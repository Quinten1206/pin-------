{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-G", "MinGW Makefiles",
                "-DCMAKE_MAKE_PROGRAM=D:/msys64/ucrt64/bin/mingw32-make.exe",
                "-DCMAKE_CXX_COMPILER=D:/msys64/ucrt64/bin/g++.exe",
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "options": {
                "env": {
                    "PATH": "D:\\msys64\\ucrt64\\bin;${env:PATH}"
                }
            }
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "dependsOn": ["CMake: Configure"],
            "options": {
                "env": {
                    "PATH": "D:\\msys64\\ucrt64\\bin;${env:PATH}"
                }
            }
        }
    ]
}
